      - run: pip install --upgrade pip && pip install -r requirements.txt
      - name: Restore cache
        uses: actions/cache@v4
        with:
          path: quantagri_historical/
          key: historical-corn-${{ github.run_number }}
          restore-keys: historical-corn-
      - name: Run corn historical
