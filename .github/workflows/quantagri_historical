      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: historical-sugar-${{ github.run_number }}
          path: quantagri_historical/
          retention-days: 90

  # Merge all commodity CSVs into one combined file and commit to repo
  merge-and-commit:
    runs-on: ubuntu-latest
    needs: [soy-historical, wheat-historical, corn-historical, cotton-historical, sugar-historical]
    if: always()
    steps:
      - uses: actions/checkout@v4

      - name: Download all artifacts
        uses: actions/download-artifact@v4
        with:
          path: all_artifacts/
          pattern: historical-*

      - name: Merge all CSVs
        run: |
          mkdir -p quantagri_historical

          # Copy all per-commodity files
          for f in all_artifacts/historical-*/quantagri_monthly_*.csv; do
            fname=$(basename "$f")
            if [ "$fname" != "quantagri_monthly_ALL.csv" ] && [ -f "$f" ]; then
              cp "$f" "quantagri_historical/$fname"
              echo "Copied: $fname"
            fi
          done

          # Build combined ALL file — header once, then data rows
          FIRST=true
          for f in quantagri_historical/quantagri_monthly_*.csv; do
            fname=$(basename "$f")
            [ "$fname" = "quantagri_monthly_ALL.csv" ] && continue
            if $FIRST; then
              cp "$f" quantagri_historical/quantagri_monthly_ALL.csv
              FIRST=false
            else
              tail -n +2 "$f" >> quantagri_historical/quantagri_monthly_ALL.csv
            fi
          done

          echo "=== Output files ==="
          wc -l quantagri_historical/*.csv

      - name: Commit historical results
        run: |
          git config user.name  "QuantAgri Bot"
          git config user.email "actions@github.com"
          git add quantagri_historical/
          git diff --staged --quiet || git commit -m \
            "data: 10yr monthly historical ${{ github.event.inputs.start_year }}-${{ github.event.inputs.end_year }} [skip ci]"
          git push

      - name: Upload merged artifact
        uses: actions/upload-artifact@v4
        with:
          name: quantagri-historical-ALL-${{ github.run_number }}
          path: quantagri_historical/
          retention-days: 90
