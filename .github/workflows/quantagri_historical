name: QuantAgri Historical Monthly (10 Year)

on:
  # Run manually from the Actions tab — this is a one-time/on-demand job
  workflow_dispatch:
    inputs:
      start_year:
        description: 'Start year'
        required: true
        default: '2006'
      end_year:
        description: 'End year'
        required: true
        default: '2025'
      resolution:
        description: 'Resolution in metres (200 recommended)'
        required: true
        default: '200'

# Each commodity runs in parallel — keeps each job well under 6h limit.
# 10 years × 1-2 regions per commodity × ~3 min/season = ~30-60 min per job.

jobs:

  soy-historical:
    runs-on: ubuntu-latest
    timeout-minutes: 360   # 6 hours max per job
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'
      - run: pip install --upgrade pip && pip install -r requirements.txt

      # Resume cache — if the job is re-run it skips already-completed season-years
      - name: Restore cache
        uses: actions/cache@v4
        with:
          path: quantagri_historical/
          key: historical-soy-${{ github.run_number }}
          restore-keys: historical-soy-

      - name: Run soy historical
        env:
          PYTHONPATH: quantagri
        run: |
          python quantagri/quantagri_historical_monthly.py \
            --commodities soy \
            --start_year ${{ github.event.inputs.start_year || '2016' }} \
            --end_year   ${{ github.event.inputs.end_year   || '2025' }} \
            --resolution ${{ github.event.inputs.resolution || '200'  }} \
            --output_dir quantagri_historical

      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: historical-soy-${{ github.run_number }}
          path: quantagri_historical/
          retention-days: 90

  wheat-historical:
